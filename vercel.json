{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/election-calender", "dest": "/election-calender.html" },
    { "src": "/election-calendar", "dest": "/election-calender.html" },
    { "src": "/campaign-brand-builder", "dest": "/Campaign_Brand_Builder_v2.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
